# Aisalon GAS WebApp URL（認証・換金申請・デポジット確認 全て共通）
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/your-aisalon-web-app-id/exec

# Aisalon GAS管理者キー（デポジット確認・消費・ステータス更新に使用）— サーバー専用
AISALON_GAS_URL=https://script.google.com/macros/s/your-aisalon-web-app-id/exec
AISALON_GAS_KEY=your-aisalon-admin-api-key

# Lootify GASのシート書き戻し用キー（GASのScript Properties LOOTIFY_API_KEY と同値にする）
LOOTIFY_GAS_KEY=your-lootify-update-api-key
